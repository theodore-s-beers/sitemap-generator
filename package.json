{
  "name": "@t6e/sitemap-generator",
  "version": "0.3.0",
  "description": "Easily create XML sitemaps for your website",
  "keywords": [
    "sitemap",
    "xml",
    "sitemap.xml",
    "generator",
    "crawler",
    "seo",
    "google"
  ],
  "homepage": "https://github.com/theodore-s-beers/sitemap-generator#readme",
  "bugs": {
    "url": "https://github.com/theodore-s-beers/sitemap-generator/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/theodore-s-beers/sitemap-generator.git"
  },
  "license": "MIT",
  "author": "Theodore Beers",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc",
    "check": "tsc --noEmit",
    "format": "prettier --write .",
    "knip": "knip",
    "lint": "prettier --check . && eslint .",
    "prepublishOnly": "npm run build",
    "test": "vitest run"
  },
  "dependencies": {
    "crawlee": "^3.16.0",
    "mitt": "3.0.1",
    "normalize-url": "9.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tsconfig/recommended": "^1.0.13",
    "@types/node": "^25.6.0",
    "eslint": "^10.2.1",
    "globals": "^17.5.0",
    "knip": "^6.6.2",
    "prettier": "3.8.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
